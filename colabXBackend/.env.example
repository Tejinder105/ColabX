NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/colabx

# Comma-separated URLs
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
TRUSTED_ORIGINS=http://localhost:5173

# Public backend URL used by better-auth callbacks
BACKEND_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# Application URL (used for invitation email links)
APP_URL=http://localhost:5173

# Email Configuration (Resend)
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
SENDER_EMAIL=noreply@colabx.io

# Optional Google OAuth (leave empty to disable Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

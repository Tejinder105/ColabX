NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/colabx
BETTER_AUTH_SECRET=

# Comma-separated URLs
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
TRUSTED_ORIGINS=http://localhost:5173

# Public backend URL used by better-auth callbacks
BACKEND_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# Application URL (used for invitation email links)
APP_URL=http://localhost:5173

# Email Configuration (Nodemailer + SMTP)
# For Gmail: get app password from https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com
SMTP_SECURE=false

# Optional Google OAuth (leave empty to disable Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

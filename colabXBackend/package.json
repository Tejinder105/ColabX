{
  "name": "colabxbackend",
  "version": "1.0.0",
  "description": "ColabX Backend",
  "license": "ISC",
  "author": "Tejinderpal Singh",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check": "npm run typecheck",
    "test": "echo \"Error: no test specified\" && exit 1",
    "db:generate": "npx tsx node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "npx tsx node_modules/drizzle-kit/bin.cjs migrate",
    "db:push": "npx tsx node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "npx tsx node_modules/drizzle-kit/bin.cjs studio"
  },
  "dependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "better-auth": "^1.4.18",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "pg": "^8.17.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.1.0",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.2",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
